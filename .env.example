# Supabase / PostgreSQL (connection string do Supabase)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Auth (sessão simples - chave para JWT/cookie)
AUTH_SECRET="uma-chave-secreta-longa-e-aleatoria"

# S3-compatible storage (ex: Supabase Storage, MinIO, AWS S3)
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="scrumflow-anexos"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_PUBLIC_URL=""  # URL base pública do bucket (opcional, para links diretos)
